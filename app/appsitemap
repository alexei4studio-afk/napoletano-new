import { MetadataRoute } from 'next'
import { createClient } from '@supabase/supabase-js'

const supabase = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!
)

export default async function sitemap(): Promise<MetadataRoute.Sitemap> {
  const baseUrl = 'https://napoletano.ro'

  // Luăm toate imaginile din baza de date pentru sitemap
  const { data: images } = await supabase
    .from('gallery_items')
    .select('url, created_at, alt_text')

  const imageEntries = (images || []).map((img) => ({
    url: `${baseUrl}/galerie-napoletano`,
    lastModified: new Date(img.created_at),
    changeFrequency: 'monthly' as const,
    priority: 0.7,
    // Nota: Next.js sitemap standard nu suportă nativ tag-uri de imagine 
    // dar Google le vede prin crawling dacă URL-ul paginii e aici.
  }))

  return [
    {
      url: baseUrl,
      lastModified: new Date(),
      changeFrequency: 'daily',
      priority: 1,
    },
    {
      url: `${baseUrl}/galerie-napoletano`,
      lastModified: new Date(),
      changeFrequency: 'weekly',
      priority: 0.8,
    },
    ...imageEntries,
  ]
}